@model eVote360.Domain.Entities.Ciudadano

@{
    ViewData["Title"] = "Crear Ciudadano";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="Crear" method="post">
    <div class="form-group">
        <label>Nombre Completo</label>
        <input asp-for="NombreCompleto" class="form-control" />
    </div>

    <div class="form-group">
        <label>Cédula</label>
        <input asp-for="Cedula" class="form-control" />
    </div>

    <div class="form-group">
        <label>Dirección</label>
        <input asp-for="Direccion" class="form-control" />
    </div>

    <div class="form-group">
        <label>Fecha Nacimiento</label>
        <input asp-for="FechaNacimiento" type="date" class="form-control" />
    </div>

    <div class="form-group">
        <label>Sexo</label>
        <input asp-for="Sexo" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success mt-2">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Cancelar</a>
</form>

