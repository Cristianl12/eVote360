@model eVote360.Domain.Entities.Candidato

<h2>Agregar Candidato</h2>

<form asp-action="Crear" method="post">
    <div class="form-group">
        <label>Nombre Completo</label>
        <input asp-for="NombreCompleto" class="form-control" />
        <span asp-validation-for="NombreCompleto" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Cargo</label>
        <input asp-for="Cargo" class="form-control" />
        <span asp-validation-for="Cargo" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Partido</label>
        <select asp-for="PartidoId" class="form-control"
                asp-items="@(new SelectList(ViewBag.Partidos, "Id", "Nombre", Model?.PartidoId))">
            <option value="">Seleccione un partido...</option>
        </select>
        <span asp-validation-for="PartidoId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success mt-2">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Cancelar</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}


